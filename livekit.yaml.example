port: 7890
prometheus:
  port: 6789
bind_addresses:
  - ""

rtc:
  tcp_port: 7891
  udp_port: 7892
  use_external_ip: false
  node_ip: 203.0.113.10        # CHANGE to this server's public IPv4
  ips:
    excludes:
      - "::/0"                 # drop all IPv6 candidates
      - "172.16.0.0/12"        # drop docker bridge candidates

# Shared coordination bus with the ingress service (the bridged livekit reaches
# valkey by service name; the host-networked ingress reaches it on 127.0.0.1:6400).
redis:
  address: valkey:6379

keys:
  # CHANGE THIS, then enter the SAME key + secret in
  # Admin -> Settings -> Voice Chat so the app and the server agree.
  devkey: devsecret_change_me_to_a_long_random_value

webhook:
  api_key: devkey
  urls:
    - http://sixth-world-sunday:4323/api/v1/livekit/webhook

turn:
  enabled: false
