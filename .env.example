# HTTP port the Go server listens on (read in main.go; defaults to 4323).
PORT=4323

# Public base URL, used for CORS and for absolute links in emails, OG embeds,
# and notifications. Must match the port the server actually listens on.
# (Stored as the base_url site setting; env value seeds the default.)
BASE_URL=http://localhost:4323

# Directory for uploaded files (relative to the working dir).
UPLOAD_DIR=uploads

# Initial log level (overridable from the admin panel at runtime).
LOG_LEVEL=info

# Database connection. Either set DATABASE_URL directly, or rely on the discrete
# POSTGRES_* vars (POSTGRES_USER/PASSWORD/DB live in postgres.env).
# DATABASE_URL=postgres://sixthworld:changeme@postgres:5432/sixth_world_sunday?sslmode=disable
POSTGRES_HOST=postgres
# Postgres port the app connects to. This is the in-container port (5432) under
# docker-compose. For an app-on-host / Postgres-in-Docker setup, the compose
# file maps Postgres to host port 5017, so use POSTGRES_PORT=5017 there.
POSTGRES_PORT=5432
POSTGRES_SSL_MODE=disable
