<!DOCTYPE html>
<html>
<head><meta charset="utf-8"></head>
<body style="margin:0;padding:0;background:#1a1a2e;color:#e0d0c0;font-family:Georgia,serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#1a1a2e;padding:40px 0;">
    <tr><td align="center">
      <table width="600" cellpadding="0" cellspacing="0" style="background:#252540;border:1px solid rgba(180,160,120,0.3);border-radius:8px;">
        <tr><td style="padding:32px 40px 24px;border-bottom:1px solid rgba(180,160,120,0.15);">
          <h2 style="margin:0;color:#ff2d78;font-size:18px;font-weight:600;">Confirm your email</h2>
        </td></tr>
        <tr><td style="padding:24px 40px;">
          <p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#e0d0c0;">
            Welcome to <strong style="color:#ff2d78;">{{.SiteName}}</strong>. Please confirm this email address so you can post and recover your account if you ever lose your password.
          </p>
          <p style="margin:0 0 24px;">
            <a href="{{.LinkURL}}" style="display:inline-block;padding:10px 24px;background:#ff2d78;color:#1a1a2e;text-decoration:none;border-radius:4px;font-weight:600;font-size:14px;">Confirm email</a>
          </p>
          <p style="margin:0 0 8px;font-size:13px;line-height:1.6;color:#b0a090;">
            This link expires in 24 hours. If you did not create this account, you can safely ignore this email.
          </p>
          <p style="margin:0;font-size:12px;line-height:1.6;color:#888;word-break:break-all;">{{.LinkURL}}</p>
        </td></tr>
        <tr><td style="padding:16px 40px;border-top:1px solid rgba(180,160,120,0.15);text-align:center;">
          <p style="margin:0;font-size:12px;color:#888;">{{.SiteName}}</p>
        </td></tr>
      </table>
    </td></tr>
  </table>
</body>
</html>
